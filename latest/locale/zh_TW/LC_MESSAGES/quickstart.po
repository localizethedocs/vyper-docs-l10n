#: ../../../quickstart.rst:43
msgid "Installing Moccasin"
msgstr ""

#: ../../../quickstart.rst:45
msgid ""
"We recommend installing Moccasin using `uv <https://docs.astral.sh/uv/>`_:"
msgstr ""

#: ../../../quickstart.rst:47
msgid ""
"# Install uv (if you don't have it)\n"
"curl -LsSf https://astral.sh/uv/install.sh | sh\n"
"\n"
"# Install Moccasin\n"
"uv tool install moccasin"
msgstr ""

#: ../../../quickstart.rst:55
msgid "Verify it works:"
msgstr ""

#: ../../../quickstart.rst:57
msgid "mox --version"
msgstr ""

#: ../../../quickstart.rst:61
msgid "You should see something like ``Moccasin CLI v0.4.3``."
msgstr ""

#: ../../../quickstart.rst:65
msgid "**Using uv vs pip**"
msgstr ""

#: ../../../quickstart.rst:67
msgid ""
"We recommend ``uv tool install`` because it handles Python environment "
"isolation automatically. If you prefer pip, you can use ``pip install "
"moccasin``, but you may need to manage virtual environments yourself."
msgstr ""

#: ../../../quickstart.rst:72
msgid "Creating a Project"
msgstr ""

#: ../../../quickstart.rst:74
msgid ""
"mox init my_project\n"
"cd my_project"
msgstr ""

#: ../../../quickstart.rst:79
msgid "This creates a ready-to-use project structure:"
msgstr ""

#: ../../../quickstart.rst:81
msgid ""
"my_project/\n"
"├── src/              # Your Vyper contracts\n"
"├── tests/            # Your tests\n"
"├── script/           # Deployment scripts\n"
"└── moccasin.toml     # Configuration"
msgstr ""

