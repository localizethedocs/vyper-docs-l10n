#: ../../../quickstart.rst:117
msgid "Exploring the Sample Contract"
msgstr ""

#: ../../../quickstart.rst:119
msgid "Open ``src/Counter.vy`` to see a minimal Vyper contract:"
msgstr ""

#: ../../../quickstart.rst:121
msgid ""
"#pragma version ^0.4.1\n"
"\n"
"number: public(uint256)\n"
"\n"
"@external\n"
"def set_number(new_number: uint256):\n"
"    self.number = new_number\n"
"\n"
"@external\n"
"def increment():\n"
"    self.number += 1"
msgstr ""

#: ../../../quickstart.rst:135
msgid "This demonstrates:"
msgstr ""

#: ../../../quickstart.rst:137
msgid ""
"**Version pragma:** ``#pragma version ^0.4.1`` specifies the compiler version"
msgstr ""

#: ../../../quickstart.rst:138
msgid ""
"**State variables:** ``number: public(uint256)`` creates storage with an "
"automatic getter"
msgstr ""

#: ../../../quickstart.rst:139
msgid ""
"**Functions:** ``@external`` marks functions callable from outside the "
"contract"
msgstr ""

