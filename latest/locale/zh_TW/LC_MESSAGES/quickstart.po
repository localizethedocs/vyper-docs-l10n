#: ../../../quickstart.rst:25
msgid "**What about Foundry, Hardhat, or Ape?**"
msgstr ""

#: ../../../quickstart.rst:27
msgid ""
"**Foundry:** Primarily for Solidity. Vyper support exists but requires "
"workarounds."
msgstr ""

#: ../../../quickstart.rst:28
msgid ""
"**Hardhat:** JavaScript-based, has a Vyper plugin, but not the recommended "
"path."
msgstr ""

#: ../../../quickstart.rst:29
msgid "**Ape:** Good if you need multi-language support, but adds complexity."
msgstr ""

#: ../../../quickstart.rst:30
msgid "**Brownie:** Deprecated. Do not use for new projects."
msgstr ""

