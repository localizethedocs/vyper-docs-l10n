"thorough review and testing."
msgstr ""

#: ../../../vyper-by-example/name-registry.rst:12
msgid ""
"A minimal name registry that maps names to addresses. Once a name is "
"registered, it cannot be changed."
msgstr ""

#: ../../../vyper-by-example/name-registry.rst:15
msgid ""
"#pragma version >0.3.10\n"
"\n"
"registry: HashMap[Bytes[100], address]\n"
"\n"
"@external\n"
"def register(name: Bytes[100], owner: address):\n"
"    assert self.registry[name] == empty(address)  # check name has not been "
"set yet.\n"
"    self.registry[name] = owner\n"
"\n"
"\n"
"@view\n"
"@external\n"
"def lookup(name: Bytes[100]) -> address:\n"
"    return self.registry[name]\n"
msgstr ""

