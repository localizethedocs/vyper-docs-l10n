#: ../../../types.rst:391
msgid ""
"# Defining a flag with two members\n"
"flag Roles:\n"
"    ADMIN\n"
"    USER\n"
"\n"
"# Declaring a flag variable\n"
"role: Roles = Roles.ADMIN\n"
"\n"
"# Returning a member\n"
"return Roles.ADMIN"
msgstr ""

#: ../../../types.rst:417
msgid "``x in y``"
msgstr ""

